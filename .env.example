# =============================================================================
# Flowgate Automation - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# --- n8n Authentication (Basic Auth) ---
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-in-production

# --- n8n Networking ---
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# --- n8n Execution ---
# Prune old executions to save disk space (max age in hours, 168h = 7 days)
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168

# --- n8n Observability ---
N8N_METRICS=true
N8N_METRICS_INCLUDE_DEFAULT_METRICS=true
N8N_LOG_LEVEL=info

# --- External API Endpoints ---
# URL da API externa para buscar usuarios
USERS_API_URL=https://jsonplaceholder.typicode.com/users

# Webhook de destino para cadastro (substitua pelo seu endpoint real)
CRM_WEBHOOK_URL=https://webhooksite.net/your-unique-id

# --- Security ---
# JWT secret for n8n internal encryption (generate with: openssl rand -hex 32)
# N8N_ENCRYPTION_KEY=
